# Confiq Environment Configuration
# Скопируйте этот файл в .env и настройте значения для вашего окружения

# ======================
# АДМИНИСТРАТИВНЫЕ НАСТРОЙКИ
# ======================

# Логин администратора по умолчанию
ADMIN_LOGIN=admin

# Пароль администратора по умолчанию (ОБЯЗАТЕЛЬНО ИЗМЕНИТЕ!)
ADMIN_PASSWORD=admin123

# ======================
# БЕЗОПАСНОСТЬ
# ======================

# Секретный ключ для сессий Flask (ОБЯЗАТЕЛЬНО ИЗМЕНИТЕ НА ПРОИЗВОДСТВЕ!)
# Используйте: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-please-use-strong-random-key

# ======================
# FLASK НАСТРОЙКИ
# ======================

# Режим работы Flask (development/production)
FLASK_ENV=production

# Основной файл приложения
FLASK_APP=app.py

# ======================
# БАЗА ДАННЫХ
# ======================

# Путь к файлу SQLite базы данных
# По умолчанию: sqlite:///data/warp_manager.db
# DATABASE_URL=sqlite:///data/warp_manager.db

# ======================
# СЕРВЕР
# ======================

# Порт для веб-сервера
PORT=8000

# Хост для веб-сервера
HOST=0.0.0.0

# Количество worker процессов для Gunicorn
WORKERS=4

# Таймаут для запросов (в секундах)
TIMEOUT=120

# ======================
# NGINX & SSL CERTIFICATES
# ======================

# Для работы HTTPS укажите домен и email
CERTBOT_DOMAIN=your-domain.com
CERTBOT_EMAIL=admin@example.com

# ======================
# ЛОГИРОВАНИЕ
# ======================

# Уровень логирования (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ======================
# CLOUDFLARE API
# ======================

# Базовый URL для Cloudflare WARP API (обычно не нужно менять)
CLOUDFLARE_API_BASE=https://api.cloudflareclient.com/v0i1909051800

# Таймаут для запросов к Cloudflare API (в секундах)
API_TIMEOUT=30

# ======================
# ЛИМИТЫ И ОГРАНИЧЕНИЯ
# ======================

# Лимит конфигураций для новых пользователей по умолчанию
DEFAULT_CONFIG_LIMIT=5

# Максимальное количество конфигураций для обычного пользователя
MAX_CONFIG_LIMIT=100

# ======================
# ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ
# ======================

# Включение режима отладки (true/false)
DEBUG=false

# Автоматическое обновление схемы БД при запуске (true/false)
AUTO_UPDATE_DB=true

# Интервал очистки старых сессий (в часах)
CLEANUP_INTERVAL=24

# Отображение информационного баннера на страницах пользователя (true/false)
# Содержимое баннера редактируется в файле info.html
INFO_BANNER=true
